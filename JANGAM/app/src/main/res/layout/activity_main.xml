<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#000000">

    <com.airbnb.lottie.LottieAnimationView
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:scaleType="centerCrop"
         android:alpha="1.0"
         app:lottie_rawRes="@raw/zoro"
         app:lottie_speed="0.8"
         android:id="@+id/backgroundAnimation"
         app:lottie_autoPlay="true"
         app:lottie_loop="true" />

    <LinearLayout
         android:layout_height="match_parent"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical">

        <ScrollView
             android:layout_height="0dp"
             android:layout_width="match_parent"
             android:fillViewport="true"
             android:layout_weight="1">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:orientation="vertical">

                <androidx.cardview.widget.CardView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     app:cardElevation="8dp"
                     app:cardUseCompatPadding="true"
                     app:cardBackgroundColor="#FFFFFFFF"
                     app:cardCornerRadius="18dp">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:gravity="center"
                         android:padding="20dp"
                         android:orientation="vertical">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:layout_marginBottom="12dp"
                             android:gravity="center"
                             android:textSize="16sp"
                             android:textColor="#000000"
                             android:text="Subscription time will expire on"
                             android:textStyle="bold" />

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:gravity="center"
                             android:orientation="horizontal">

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginEnd="8dp"
                                 android:gravity="center"
                                 android:orientation="vertical">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="32sp"
                                     android:textColor="#E74C3C"
                                     android:id="@+id/tv_d"
                                     android:text="55"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="12sp"
                                     android:textColor="#000000"
                                     android:text="Day" />

                            </LinearLayout>

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginHorizontal="5dp"
                                 android:textSize="32sp"
                                 android:textColor="#000000"
                                 android:text=":"
                                 android:textStyle="bold" />

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginEnd="8dp"
                                 android:gravity="center"
                                 android:orientation="vertical">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="32sp"
                                     android:textColor="#E74C3C"
                                     android:id="@+id/tv_h"
                                     android:text="15"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="12sp"
                                     android:textColor="#000000"
                                     android:text="Hours" />

                            </LinearLayout>

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginHorizontal="5dp"
                                 android:textSize="32sp"
                                 android:textColor="#000000"
                                 android:text=":"
                                 android:textStyle="bold" />

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginEnd="8dp"
                                 android:gravity="center"
                                 android:orientation="vertical">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="32sp"
                                     android:textColor="#E74C3C"
                                     android:id="@+id/tv_m"
                                     android:text="41"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="12sp"
                                     android:textColor="#000000"
                                     android:text="Minute" />

                            </LinearLayout>

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:layout_marginHorizontal="5dp"
                                 android:textSize="32sp"
                                 android:textColor="#000000"
                                 android:text=":"
                                 android:textStyle="bold" />

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:gravity="center"
                                 android:orientation="vertical">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="32sp"
                                     android:textColor="#E74C3C"
                                     android:id="@+id/tv_s"
                                     android:text="25"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="12sp"
                                     android:textColor="#000000"
                                     android:text="Seconds" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     app:cardElevation="8dp"
                     app:cardUseCompatPadding="true"
                     app:cardBackgroundColor="#FFFFFFFF"
                     app:cardCornerRadius="18dp">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:padding="20dp"
                         android:orientation="vertical">

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:layout_marginBottom="16dp"
                             android:orientation="horizontal">

                            <ImageView
                                 android:layout_height="64dp"
                                 android:layout_width="64dp"
                                 android:src="@drawable/pubg_india"
                                 android:scaleType="centerCrop"
                                 android:contentDescription="PUBG INDIA"
                                 android:layout_marginEnd="16dp"
                                 android:id="@+id/myIcon" />

                            <LinearLayout
                                 android:layout_height="wrap_content"
                                 android:layout_width="0dp"
                                 android:orientation="vertical"
                                 android:layout_weight="1">

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:layout_marginBottom="6dp"
                                     android:textSize="20sp"
                                     android:textColor="#000000"
                                     android:text="PUBG INDIA"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:layout_marginBottom="4dp"
                                     android:textSize="14sp"
                                     android:textColor="#555555"
                                     android:text="Version: 4.2.0" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:layout_marginBottom="4dp"
                                     android:textSize="14sp"
                                     android:textColor="#27AE60"
                                     android:text="Status: Live"
                                     android:textStyle="bold" />

                                <TextView
                                     android:layout_height="wrap_content"
                                     android:layout_width="wrap_content"
                                     android:textSize="13sp"
                                     android:textColor="#555555"
                                     android:text="Package: com.pubg.imobile" />

                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:gravity="center"
                             android:orientation="horizontal">

                            <Button
                                 android:layout_height="48dp"
                                 android:layout_width="0dp"
                                 android:layout_marginEnd="8dp"
                                 android:textSize="14sp"
                                 android:backgroundTint="#95A5A6"
                                 android:textAllCaps="true"
                                 android:textColor="#FFFFFF"
                                 android:layout_weight="1"
                                 android:id="@+id/stophack"
                                 android:text="UNINSTALL GAME"
                                 android:textStyle="bold" />

                            <Button
                                 android:layout_height="48dp"
                                 android:layout_width="0dp"
                                 android:textSize="14sp"
                                 android:backgroundTint="#2980B9"
                                 android:textAllCaps="true"
                                 android:textColor="#FFFFFF"
                                 android:layout_marginStart="8dp"
                                 android:layout_weight="1"
                                 android:id="@+id/starthack"
                                 android:text="INSTALL GAME"
                                 android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="10dp"
                     android:gravity="center"
                     android:alpha="0.7"
                     android:textSize="12sp"
                     android:textColor="#000000"
                     android:layout_marginTop="400dp"
                     android:text="@All Rights Reserved . By zoro0687"
                     android:textStyle="bold" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</RelativeLayout>